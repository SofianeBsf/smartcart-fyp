DATABASE_URL=postgresql://smartcart:smartcart_password@localhost:5432/smartcart
AI_SERVICE_URL=http://localhost:8000
JWT_SECRET=change-me
OWNER_OPEN_ID=dev-admin
DEV_LOGIN_TOKEN=change-me

# Chatbot LLM (Google Gemini via OpenAI-compatible endpoint)
BUILT_IN_FORGE_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
BUILT_IN_FORGE_API_KEY=your-gemini-api-key-here

# Email links (verification, password reset, order details)
BASE_URL=http://localhost:3000

# Email (Resend) - preferred, works from cloud hosts that block SMTP (e.g. Render)
RESEND_API_KEY=re_your_api_key_here
# Verified sender address. If unset, uses onboarding@resend.dev which on the free
# tier can ONLY deliver to the email tied to your Resend account. To send to any
# user, verify a domain in the Resend dashboard and set this to e.g.
# RESEND_FROM_EMAIL="SmartCart <noreply@yourdomain.com>"
RESEND_FROM_EMAIL=

# Gmail SMTP via Nodemailer
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password